export function renderWithCitations(text, sources) {
    const html = md.render(text);
    if (!sources || sources.length === 0) return html;
    
    const div = document.createElement('div');
    div.innerHTML = html;
    
    const walker = document.createTreeWalker(div, NodeFilter.SHOW_TEXT, {
        acceptNode: function(node) {
            let parent = node.parentNode;
            while (parent && parent !== div) {
                if (parent.tagName === 'CODE' || parent.tagName === 'PRE' || parent.tagName === 'A') {
                    return NodeFilter.FILTER_REJECT;
                }
                parent = parent.parentNode;
            }
            return NodeFilter.FILTER_ACCEPT;
        }
    });
    
    const nodesToReplace = [];
    while(walker.nextNode()) {
        const node = walker.currentNode;
        if (/\[\d+\]/.test(node.textContent)) {
            nodesToReplace.push(node);
        }
    }
    
    nodesToReplace.forEach(node => {
        const content = node.textContent;
        const fragment = document.createElement('span');
        
        // 匹配多个相邻引用或单个引用，如 [1], [1][2], [1,2] 等
        const regex = /\[(\d+(?:,\s*\d+)*)\]/g;
        let lastIndex = 0;
        let match;
        
        while ((match = regex.exec(content)) !== null) {
            // Add text before match
            if (match.index > lastIndex) {
                fragment.appendChild(document.createTextNode(content.substring(lastIndex, match.index)));
            }
            
            // Extract all numbers from the match
            const ids = match[1].split(',').map(id => id.trim());
            
            // Render links
            ids.forEach((id, idx) => {
                const sourceIndex = parseInt(id) - 1;
                if (sourceIndex >= 0 && sourceIndex < sources.length) {
                    const a = document.createElement('a');
                    a.href = sources[sourceIndex].url;
                    a.className = 'citation-link';
                    a.textContent = id;
                    a.target = '_blank';
                    a.rel = 'noopener noreferrer';
                    a.title = sources[sourceIndex].title;
                    fragment.appendChild(a);
                    
                    if (idx < ids.length - 1) {
                        fragment.appendChild(document.createTextNode(', '));
                    }
                } else {
                    fragment.appendChild(document.createTextNode(`[${id}]`));
                }
            });
            
            lastIndex = regex.lastIndex;
        }
        
        if (lastIndex < content.length) {
            fragment.appendChild(document.createTextNode(content.substring(lastIndex)));
        }
        
        if (fragment.childNodes.length > 0) {
            node.parentNode.replaceChild(fragment, node);
        }
    });
    
    // Add sources block at the end if we have sources
    const sourcesBlock = document.createElement('div');
    sourcesBlock.className = 'references-block';
    
    const sourcesHeader = document.createElement('strong');
    sourcesHeader.textContent = '参考资料';
    sourcesBlock.appendChild(sourcesHeader);
    
    const sourcesList = document.createElement('ol');
    sources.forEach((source, idx) => {
        const li = document.createElement('li');
        li.id = `source-${idx + 1}`;
        const a = document.createElement('a');
        a.href = source.url;
        a.textContent = source.title || source.url;
        a.target = '_blank';
        a.rel = 'noopener noreferrer';
        li.appendChild(a);
        sourcesList.appendChild(li);
    });
    sourcesBlock.appendChild(sourcesList);
    div.appendChild(sourcesBlock);
    
    return div.innerHTML;
}
