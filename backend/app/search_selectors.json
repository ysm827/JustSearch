{
    "google": {
        "base_url": "https://www.google.com/search?q={query}&num={num}&hl=en",
        "selectors": {
            "result_container": [
                "div.g",
                "#rso > div",
                "[data-sokoban-container]",
                "[data-ved]"
            ],
            "title": "h3, div[role='heading']",
            "link": "a[href]:not([href^=\"#\"]):not([href^=\"/search\"])",
            "snippet": "div[style*='-webkit-line-clamp'], div.IsZvec, .VwiC3b, [data-sncf], .hb8SA",
            "date": ".LEwnzc, span.f, span.dna-a"
        },
        "wait_selector": "#rso, [data-ved]"
    },
    "bing": {
        "base_url": "https://www.bing.com/search?q={query}",
        "selectors": {
            "result_container": [
                "li.b_algo"
            ],
            "title": "h2",
            "link": "h2 a",
            "snippet": ".b_caption p, .b_algoSlug, .b_lineclamp2",
            "date": ".news_dt, .b_demoteText"
        },
        "wait_selector": "#b_results"
    },
    "duckduckgo": {
        "base_url": "https://duckduckgo.com/?q={query}",
        "selectors": {
            "result_container": [
                "article[data-testid='result']",
                ".react-results--main li",
                "[data-result]",
                ".result",
                ".web-result",
                "li[data-layout='organic']"
            ],
            "title": "h2, [data-testid='result-title'], .result__title a, .result__a",
            "link": "a[data-testid='result-title-a'], h2 a, .result__a, .result__title a",
            "snippet": "[data-testid='result-snippet'], .result__snippet, .result_snippet",
            "date": ".result__timestamp"
        },
        "wait_selector": "#react-layout, .react-results--main, article[data-testid='result']"
    },
    "sogou": {
        "base_url": "https://www.sogou.com/web?query={query}",
        "selectors": {
            "result_container": [
                "div.vrwrap",
                "div.rb"
            ],
            "title": "h3 a",
            "link": "h3 a",
            "snippet": ".str-text-info, .str_info",
            "date": ".fb"
        },
        "wait_selector": "#main, .results"
    },
    "brave": {
        "base_url": "https://search.brave.com/search?q={query}",
        "selectors": {
            "result_container": [
                "div.snippet",
                "#results .snippet"
            ],
            "title": "a.result-header, .title",
            "link": "a.result-header, .title a",
            "snippet": ".snippet-description, .snippet-content p",
            "date": ""
        },
        "wait_selector": "#results, .snippet"
    },
    "baidu": {
        "base_url": "https://www.baidu.com/s?wd={query}&rn={num}",
        "selectors": {
            "result_container": [
                ".c-container",
                "#content_left .result",
                ".result"
            ],
            "title": "h3 a, .t a",
            "link": "h3 a, .t a",
            "snippet": ".c-abstract, .c-span9, .c-color-text",
            "date": ".newTimeFactor__time, .c-color-gray"
        },
        "wait_selector": "#content_left, .c-container"
    },
    "yandex": {
        "base_url": "https://yandex.com/search/?text={query}",
        "selectors": {
            "result_container": [
                "li.serp-item",
                ".serp-item"
            ],
            "title": "h2 a, .OrganicTitleLink",
            "link": "h2 a, .OrganicTitleLink",
            "snippet": ".OrganicText, .text-container",
            "date": ".OrganicTimestamp"
        },
        "wait_selector": ".serp-list, .content"
    }
}