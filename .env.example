# JustSearch 环境变量配置
# 复制此文件为 .env 并修改

# 浏览器无头模式（Docker 部署保持 true）
HEADLESS=true

# CORS 允许的源（逗号分隔，* 为全部；默认仅允许本机访问）
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost,http://127.0.0.1

# 最大并发浏览器页面数
MAX_CONCURRENT_PAGES=10

# 本机 Docker 部署建议保持 true；首页会为 localhost 自动注入访问令牌
JUSTSEARCH_AUTH_ENABLED=true

# 备用 API Key（建议通过 UI 配置）
# OPENAI_API_KEY=sk-xxx
